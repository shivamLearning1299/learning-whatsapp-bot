# Copy this to .env for LOCAL testing only. Never commit the real .env file.
# In production (GitHub Actions), these are set as repo secrets instead — see README.md.

ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio's WhatsApp sandbox number — same for everyone during sandbox testing
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Your own WhatsApp number, in E.164 format, prefixed with "whatsapp:"
MY_WHATSAPP_TO=whatsapp:+91XXXXXXXXXX
